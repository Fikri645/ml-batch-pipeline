# ── PostgreSQL credentials (shared by Docker Compose + src/config.py) ────────
DB_USER=pipeline_user
DB_PASSWORD=pipeline_pass
DB_NAME=pipeline_db
DB_HOST=localhost
DB_PORT=5432

# Derived connection URL — used when running scripts outside Docker
DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Airflow secrets ───────────────────────────────────────────────────────────
# docker-compose maps these to AIRFLOW__CORE__FERNET_KEY etc. on the container.
# Generate Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=          # any random string, e.g. openssl rand -hex 32

# ── Airflow admin user (created on first `docker compose run airflow-init`) ──
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# ── Model artifact ────────────────────────────────────────────────────────────
# Path inside the Airflow container (project is mounted at /opt/airflow/project)
MODEL_PATH=/opt/airflow/project/models/lgbm_fraud.pkl

# ── Pipeline tuning ───────────────────────────────────────────────────────────
BATCH_SIZE=500
FRAUD_RATE_BASELINE=0.006
PSI_ALERT_THRESHOLD=0.2
REFERENCE_WINDOW_DAYS=30

# ── GCP (Cloud Run scorer) ────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1
ARTIFACT_REGISTRY_REPO=ml-batch-pipeline
CLOUD_RUN_JOB_NAME=fraud-scorer

# ── Alerts (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=
