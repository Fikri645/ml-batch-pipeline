# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Connection URL for the pipeline database (not the Airflow metadata DB)
DATABASE_URL=postgresql://pipeline_user:pipeline_pass@localhost:5432/pipeline_db

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow_meta
AIRFLOW__CORE__FERNET_KEY=           # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=      # any random string

# ── PostgreSQL container (docker-compose) ─────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=airflow_meta

# Pipeline DB user (created by init-multiple-dbs.sh)
PIPELINE_DB_USER=pipeline_user
PIPELINE_DB_PASSWORD=pipeline_pass
PIPELINE_DB_NAME=pipeline_db

# ── Airflow admin user ────────────────────────────────────────────────────────
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# ── Model artifact ────────────────────────────────────────────────────────────
MODEL_PATH=/opt/airflow/project/models/lgbm_fraud.pkl

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=/opt/airflow/project/dbt
DBT_PROJECT_DIR=/opt/airflow/project/dbt

# ── GCP (Cloud Run scorer) ────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1
ARTIFACT_REGISTRY_REPO=ml-batch-pipeline
CLOUD_RUN_JOB_NAME=fraud-scorer

# ── Alerts (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=
